# Telegram bot
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=                  # CSV: 123,456,789

# LLM (MiniMax API) — Smart routing unificado, Sprint 12+.
# Docs: https://api.minimax.io  (OpenAI-compatible, zero data retention).
# Migrado desde OpenCode Go (mimo/kimi/glm/deepseek-v4-flash) por:
#   - MiniMax-M3 multimodal nativo (audio LLM ya no requiere STT externo).
#   - 1M context vs 256K de Go; thinking mode nativo (sin leakage a provider).
#   - Quota mejor: $0.30/$0.60 vs Go tier $0.60/$2.40.
#
# Sprint 19.6+ Phase 5 (OpenAI Build Week): el chain es ahora
# LOCAL-FIRST. El default primary es `qwen2.5:7b` servido por Ollama
# (incluido en docker-compose.yml como servicio `ollama`). NO
# requiere API key — un juez puede clonar el repo y `docker compose up`
# y el chat funciona sin tocar este archivo.
#
# Smart routing por defecto (Sprint 19.6+ Phase 5):
# - Primary:   qwen2.5:7b            (Ollama local, 4.7 GB download, CPU OK)
# - Fallback:  MiniMax-M2.7-highspeed (cloud, solo si OPENCODE_GO_API_KEY
#                                       está seteada; si no, chain se queda
#                                       en Ollama local)
#
# Para volver al comportamiento cloud-only (Sprint 19.6+ Phase 4):
#   LLM_TEXT_PRIMARY=MiniMax-M3
#   LLM_TEXT_PRIMARY_PROVIDER=minimax
#   OPENCODE_GO_API_KEY=sk-...
# El fallback se mantiene MiniMax — solo cambia el primary.
#
# Para un chain totalmente local (primary + fallback ambos Ollama):
#   LLM_TEXT_PRIMARY=qwen2.5:7b
#   LLM_TEXT_PRIMARY_PROVIDER=ollama
#   LLM_TEXT_FALLBACK=llama3.1:8b
#   LLM_TEXT_FALLBACK_PROVIDER=ollama
# Requiere `ollama pull llama3.1:8b` además de qwen2.5:7b (4.7 + 4.9 GB).
#
# Variable names legacy (OPENCODE_GO_*) preservados para no romper scripts
# de despliegue ni Credential Manager entries existentes. NO renombrar.
OPENCODE_GO_BASE_URL=https://api.minimax.io/v1
OPENCODE_GO_API_KEY=
# Overrides opcionales — defaults en hermes/config.py. Descomentar solo si
# querés pinear un modelo específico. Si el valor es incorrecto, hermes
# recibe 404 de la API al primer chat.
# LLM_TEXT_PRIMARY=qwen2.5:7b
# LLM_TEXT_PRIMARY_PROVIDER=ollama
# LLM_TEXT_FALLBACK=MiniMax-M2.7-highspeed
# LLM_TEXT_FALLBACK_PROVIDER=minimax
# LLM_VOICE_PRIMARY=MiniMax-M3
# --- Ollama local primary (Sprint 19.6+ Phase 5) ---
# LLM_TEXT_PRIMARY__BASE_URL=http://localhost:11434/v1
#   En docker compose, el backend usa `http://ollama:11434/v1` (hostname
#   del servicio en la network interna). Para uso NO-docker (Ollama
#   corriendo en el host), usar `http://localhost:11434/v1`.
# LLM_TEXT_PRIMARY__MODEL=qwen2.5:7b
#   El modelo por default. qwen2.5:7b es ~4.7 GB en Q4_K_M, encaja
#   en el memory limit de 6 GB del servicio ollama. Alternativas:
#   llama3.1:8b (similar tamaño, mejor en inglés), mistral:7b (más
#   rápido, peor en code), phi3:mini (2.3 GB, peor calidad).
# LLM_TEXT_PRIMARY__API_KEY=ollama
#   Placeholder. Ollama ignora el valor del header Authorization, pero
#   el SDK de openai requiere un string no-vacío al construir el
#   cliente. "ollama" es la convención usada por los docs de Ollama.
# Temperatura: 0.0 determinista, 1.0 default. Subir a 0.7+ solo brainstorming.
# LLM_TEMPERATURE=1.0
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=1024
# Nucleus sampling (0-1, default 0.9). Previene drift de idioma + exoticos.
# SPRINT 18 HOTFIX (2026-07-08): bug de token repetition loops en
# respuestas largas del modelo MiMo v2.5 con caracteres chinos random.
# LLM_TOP_P=0.9
# Repetition penalty (1.0-2.0, default 1.04). Penaliza repeticion por
# cada aparicion del token. 1.04 = ~4% por repeticion, gentle.
# Subir a 1.06/1.08 si vemos loops sutiles. NO bajar de 1.0.
# Aplicado solo a path OpenAI-compat (Anthropic rechaza campos no estandar).
# LLM_REPETITION_PENALTY=1.04
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ============================================================================
# Sprint 19.6+ Phase 4 — ChatGPT 5.6 frontier tier (OpenAI Build Week)
# ============================================================================
# Optional frontier tier for explicit selection or technical-failure fallback. It is disabled by default.
# When explicitly enabled with a key, the normal product chain appends
# the frontier model after the configured primary and fallback tiers.
# Enabling it permits the selected conversation to leave the local host.
#
# LLM_TEXT_FRONTIER__MODEL defaults to the Build Week flagship identifier
# `gpt-5.6-sol`; operators may override it for compatible deployments.
# Frontier mode is explicit opt-in and sends the selected conversation.
#
# LLM_TEXT_FRONTIER__ENABLED=false
# LLM_TEXT_FRONTIER__MODEL=gpt-5.6-sol
# LLM_TEXT_FRONTIER__API_KEY=
# LLM_TEXT_FRONTIER__BASE_URL=https://api.openai.com/v1
# LLM_TEXT_FRONTIER__TIMEOUT_S=60
# LLM_TEXT_FRONTIER__MAX_TOKENS=8192
# LLM_TEXT_FRONTIER__BREAKER_FAIL_MAX=3
# LLM_TEXT_FRONTIER__BREAKER_RESET_TIMEOUT_S=120

# STT externo (Gemini 3 Flash Lite). Free tier: 500 RPD, 15 RPM.
# Decisión: STT aislado del chain LLM principal — coste (Flash Lite es
# gratis vs $0.30/$0.60 por M tokens de MiniMax-M3 multimodal) y cuota
# independiente (no acopla audio al rate limit del chat).
# Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
STT_MODEL=gemini-3.1-flash-lite
STT_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Cola STT: limita concurrencia y tasa para no saturar la cuota.
# 2 audios en paralelo + 12 RPM deja margen sobre los 15 RPM de Gemini.
STT_MAX_CONCURRENT=2
STT_PER_MINUTE=12
STT_QUEUE_TIMEOUT_S=60

# Persistence
DB_PATH=/app/data/conversations.db

# Telemetry (InfluxDB) - opcional pero recomendado.
# INFLUX_URL default `http://localhost:8086` (asume InfluxDB en el host docker).
# En LAN privada, apuntar a la IP/hostname del servidor InfluxDB.
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=
INFLUX_ORG=                # requeridad por hermes; falla si vacia
INFLUX_BUCKET=hermes

# Server
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8000
LOG_LEVEL=INFO
TZ=UTC

# OpenAI-compatible HTTP API used by the public WebUI path.
# Compose binds the port to host loopback. Authentication is optional:
# set HERMES_API_API_KEY when exposing it beyond a trusted local host.
ENABLE_HTTP_API=true
HERMES_API_HOST=0.0.0.0
HERMES_API_PORT=8000
HERMES_API_API_KEY=
# Explicit browser origins only. Never use "*" for a local unauthenticated API.
HERMES_API_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional SQLite WAL online backup. Choose a schedule and mount/export
# BACKUP_DIR with the backup system appropriate for your deployment.
BACKUP_ENABLED=true
BACKUP_DIR=/app/backups
BACKUP_KEEP=7
BACKUP_HOUR=3
BACKUP_MINUTE=30

# Tool gates. TOOLS_ENABLED exposes local built-ins such as vault search.
# OUTBOUND_TOOLS_ENABLED independently permits weather and Agent-Reach;
# leave it false for a local-only deployment.
TOOLS_ENABLED=false
OUTBOUND_TOOLS_ENABLED=false

# Web Search Router (Sprint 9.3) — privacy-first por default.
# El LLM llama a hermes_search() con intent=general|semantic|deep_research.
# Mapeo: general -> SearXNG, semantic -> Exa, deep_research -> Tavily.
#
# Activar el router. Si false, el tool no se registra y el LLM no tiene web search.
SEARCH_ENABLED=false
# URL del SearXNG container (Sprint 9.3, privacy-first metasearch).
# El container se arranca via an operator-specific Compose override (servicio `searxng`).
# Internamente: http://searxng:8080. NO exponer a internet (SearXNG no
# tiene auth por default).
SEARCH_SEARXNG_URL=http://searxng:8080
# Tavily (deep_research intent). Free tier 1.000 credits/mes sin tarjeta.
# basic=1 credit, advanced (deep_research)=2 credits.
# Key: https://tavily.com/  (NUNCA commitear el valor real al repo).
TAVILY_API_KEY=
# Monthly request ceiling (the API key above intentionally stays empty).
TAVILY_MONTHLY_LIMIT=1000
# Exa (semantic intent). Free tier: 20.000 requests/mes sin tarjeta.
# Precios verificados 2026-06-27 en https://exa.ai/pricing.
# Free tier incluye: web search tool calls, webpage text+highlights,
# latency configurable 180ms-1s.
# Paid tiers (si se excede free): Search $7/1k, Deep Search $12-15/1k,
# Agent $0.012-2.00/run, Contents $1/1k pages, Monitors $15/1k.
# SDKs oficiales: Python, JS. Tambien proveen MCP server oficial
# (alternativa futura: integrar Exa via MCP en vez de nuestro backend).
# Startup/Education grants: $1000 free credits (contactar).
# Key: https://dashboard.exa.ai  (NUNCA commitear el valor real al repo).
EXA_API_KEY=
# Monthly request ceiling (the API key above intentionally stays empty).
EXA_MONTHLY_LIMIT=20000
# Size guard: max chars totales en la respuesta al LLM. Default 200K = ~50K tokens.
# A $0.30/$0.60 per M tokens (MiniMax-M3), 200K chars ≈ $0.02 input / $0.04 output
# por search tipico. Aceptable para uso personal; bajar si se observa deriva.
SEARCH_SIZE_GUARD_CHARS=200000
# Timeouts per-backend (segundos). Tavily/Exa son hosted APIs, mas lentos.
SEARCH_TIMEOUT_SEARXNG=10.0
SEARCH_TIMEOUT_TAVILY=15.0
SEARCH_TIMEOUT_EXA=15.0
# Concurrency per-backend (max requests simultaneas a cada uno).
# SearXNG depende de engines upstream (DuckDuckGo ~5 req/s). Tavily 100 req/min. Exa 50 req/min.
SEARCH_MAX_CONCURRENT_SEARXNG=6
SEARCH_MAX_CONCURRENT_TAVILY=10
SEARCH_MAX_CONCURRENT_EXA=5
# DEPRECATED (S9.3 legacy). Se ignora si los 3 per-backend estan set. Se elimina en S9.4.
SEARCH_MAX_CONCURRENT=3
# Circuit breaker: N fails -> open por TTL segundos.
SEARCH_CIRCUIT_BREAKER_THRESHOLD=3
SEARCH_CIRCUIT_BREAKER_TTL_SECONDS=300

# Sprint 12 (ADR-007): model aliases que mapean a chains dedicadas.
# Cuando un cliente RikkaHub pide `model: "oroimen-agent-fast"`, el smart
# router usa solo MiniMax-M2.7-highspeed (sin fallback a MiniMax-M3). Util
# para title generation, background tasks y modelos rapidos sin pagar
# la cuota de M3 (multimodal, thinking).
# Formato JSON: {"alias": ["modelo1", "modelo2"]}
HERMES_LLM_MODEL_OVERRIDES={"oroimen-agent-fast": ["MiniMax-M2.7-highspeed"]}

# Sprint 12.1 (ADR-007 / TDD_S12_DELETE_AND_SYNC.md): encryption key
# para cifrar content de tombstoned conversations. Fernet (symmetric
# authenticated encryption). Generar UNA vez con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Almacenar SOLO en .env (NUNCA en repo, NUNCA en git, NUNCA en logs).
# Si se pierde, las convs tombstoned son irrecuperables (el restore
# falla con 503). Backup del .env es critico.
# Sin esta variable: soft delete hace plain archive sin cifrado
# (TDD §7.2 safe-fallback). El restore sigue funcionando para
# convs legacy (no cifradas).
#HERMES_CONVERSATION_ENCRYPTION_KEY=

# Sprint 12.1: dias de retencion de tombstoned convs antes de hard
# delete. Default 7d, rango 1-90. El job diario
# TombstonePurgeScheduler corre cada 24h y hard-deletea convs con
# purge_at <= NOW(). El CASCADE en messages borra los rows cifrados.
HERMES_CONVERSATION_RETENTION_DAYS=7

# Sprint 16 (US-3.2 memory facts retrieval): divisor del time decay
# factor. Aplicado como `score * exp(-days_since / fact_time_decay_days)`.
# Default 30 dias = balance entre "recency matters" y "facts viejos
# siguen valiendo". Rango 1-365.
FACT_TIME_DECAY_DAYS=30

# Sprint 16 (US-3.2): total de chars disponibles para el contexto del
# LLM (RAG vault + memory facts + system prompt). Default 20000 chars
# es heuristica robusta para Anthropic Sonnet 4.5 (200k token context
# window, ~4 chars/token). Rango 1000-200000.
MAX_CONTEXT_CHARS=20000

# Sprint 16 (US-3.2): porcentaje del max_context_chars reservado para
# memory facts del usuario. Memoria del usuario SIEMPRE prioridad sobre
# vault RAG — el LLM no debe olvidar quien es project owner mientras lee un
# PDF grande. 10% = ~2000 chars para facts, ~18000 chars para vault.
# Rango 0.0-0.5.
MEMORY_FACTS_TOKEN_BUDGET_PCT=0.10

# Sprint 16 (US-3.2 retrieval quality): hard threshold de cosine
# similarity. Facts con score < este valor se descartan ANTES de
# aplicar time decay. 0.82 es razonable para text-embedding-3-small
# (1536-dim). Si usas otro modelo (e.g. qwen3-embedding-8b 4096-dim),
# puede requerir ajuste. Rango 0.0-1.0.
MIN_SIMILARITY_THRESHOLD=0.82

# ============================================================================
# Sprint 17 Slice 2.5 — Vault Embeddings (PR #113c)
# ============================================================================
# Estas 5 vars controlan el EmbedWatcher (poll loop que computa embeddings
# para archivos nuevos en el vault). Si VAULT_EMBEDDING_MODEL está VACÍO,
# el watcher se salta (RAG deshabilitado, chat funciona normal).
#
# Sprint 19.5 (PR-B, 2026-07-13): defaults changed from
# "text-embedding-3-small" (1536-dim) to "qwen/qwen3-embedding-8b" (4096-dim)
# to align with the configurable multi-tier embedding architecture.
#
# VAULT_EMBEDDING_MODEL: nombre del modelo de embedding que el
#   EmbeddingsService router. Default = "qwen/qwen3-embedding-8b" (4096-dim,
#   OpenRouter; tier 3 cloud).
#   Alternativas comunes:
#     - "text-embedding-3-small" (1536-dim, OpenAI)
#     - "text-embedding-3-large" (3072-dim, OpenAI)
#     - "gemini-embedding-001" (768/1536/3072 configurable, Gemini)
#     - "qwen3-embedding:0.6b" (1024-dim, Ollama local; tier 2 edge)
#     - "qwen3-embedding:8b" (4096-dim, Ollama local; tier 2 edge)
#   VACÍO = RAG deshabilitado.
VAULT_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# VAULT_EMBEDDING_DIM: dimensionalidad del vector. DEBE coincidir con el
#   modelo. Para "qwen/qwen3-embedding-8b" = 4096. Si cambias el modelo,
#   CAMBIA TAMBIÉN esta var o los embeddings viejos se vuelven inválidos
#   (filtro text_version los ignora pero ocupan espacio).
#   ATENCIÓN: cambiar el modelo con embeddings existentes requiere re-embed
#   manual (sprint 19.5+, scripts/reembed_vault.py cuando esté listo).
VAULT_EMBEDDING_DIM=4096
# VAULT_CHUNK_MAX_TOKENS: tamaño máximo de un chunk en tokens. Default
#   1000 es heurística conservadora (text-embedding-3-small acepta 8191
#   max input). Chunks más grandes = menos embeddings = más rápido
#   pero peor retrieval (LRU-style recall degrada). Rango 100-4000.
VAULT_CHUNK_MAX_TOKENS=1000
# VAULT_CHUNK_OVERLAP_TOKENS: overlap entre chunks consecutivos (10-15% de
#   max_tokens es estándar). 100 tokens de overlap = 10% para default.
#   0 = no overlap (NO recomendado — pierde contexto en boundaries).
VAULT_CHUNK_OVERLAP_TOKENS=100
# VAULT_WATCHER_POLL_INTERVAL_S: cada cuántos segundos el EmbedWatcher
#   escanea vault_files en busca de archivos sin embeddings o con
#   text_version desactualizado. Default 300s = 5min. Rango 10-3600.
#   Si la inbox tiene muchos archivos nuevos, baja a 60s. Si está idle,
#   600s+ está bien.
VAULT_WATCHER_POLL_INTERVAL_S=300

# ============================================================================
# Sprint 19 Slice 4c — Edge PC auto-queue + zombie recovery
# ============================================================================
# Master switch: auto-queue files with Tesseract confidence < threshold to
# the edge PC when it's online. If false, all edge work needs explicit
# /edgeOCR <file_id> command. Default true (TDD §4.4.1: "eliminates a
# class of 'should I upgrade this?' decisions").
OCR_AUTO_EDGE_OCR=true
# Confidence threshold for auto-queue. Per TDD §4.4.1: "0.85, not 0.60,
# because edge is free local compute; eliminates upgrade decisions".
# Range 0.0-1.0. Below this, file is queued to edge if PC is online.
OCR_EDGE_AUTOQUEUE_THRESHOLD=0.85
# Catch-up pass drains at most this many files per reconnect event.
# Overflow stays in `pending_review` for the next reconnect. Default 1000
# = 10x worst-case "I was on travel for 2 weeks" load.
OCR_EDGE_MAX_QUEUE_SIZE=1000
# Debounce between catch-up enqueue calls. 500ms = 200 files drain in 100s.
# Avoids hammering the SMB share with rapid metadata writes.
OCR_EDGE_BATCH_DELAY_MS=500
# M6 Phase 5 zombie recovery threshold. Rows in `ocr_pending.status=
# 'edge_queued'` older than this get reset to `pending_review`. Default
# 2h = 10x worst-case LLaVA batch time on a 50-image batch (~12min serial).
OCR_EDGE_TIMEOUT_HOURS=2
# How often M6 Phase 5 runs (in seconds). Default 900s = 15min. Cheap
# SELECT on partial index, no perf concern.
OCR_EDGE_ZOMBIE_SCAN_INTERVAL=900
# Comma-separated hostnames/IPs of edge PCs to probe. Empty = no auto-queue,
# only manual /edgeOCR works. Example: "edge.local,edge.example.com".
# PC discovery: mDNS browse for _mnemosyne-edge._tcp.local, plus HTTP probe
# to each IP in this list. mDNS takes priority if both find a host.
EDGE_COMPUTERS=
# Shared-root prefix stored in vault paths. Override privately for your NAS,
# mounted share, or edge-PC layout; do not hard-code operator paths in code.
EDGE_SMB_ROOT_PREFIX=/mnt/shared/
# HTTP probe timeout per PC. Default 1s = 30s for 30 PCs in a single cycle.
EDGE_PROBE_TIMEOUT_S=1.0

# ============================================================================
# Sprint 19 Slice 4d v2 — Vault monitor folder + PARA seed (Oroimen rename)
# ============================================================================
# All env vars below use TRUE OPT-IN semantics: empty string = no behavior.
# The user MUST set these explicitly if they want non-default behavior.

# VAULT_INBOX_ROOT: root directory for the vault (default: <workdir>/Documentos).
# The drop_watcher auto-creates subdirs of this as collections.
VAULT_INBOX_ROOT=/Documentos

# VAULT_DROP_ROOT: where the watcher monitors for new files (default:
# <VAULT_INBOX_ROOT>/drop). Files dropped here get auto-linked to
# collections based on their subdir name.
VAULT_DROP_ROOT=/Documentos/_inbox

# VAULT_MONITOR_ROOTS: comma-separated list of ADDITIONAL recursive
# roots to monitor (besides VAULT_DROP_ROOT). Empty = legacy (only
# drop_root watched). Example: "/Documentos" to watch the whole vault,
# or "/data/Photos,/data/Music" for two extra roots.
# IMPORTANT: these paths must NOT be under VAULT_DROP_ROOT (M6 partition
# rule; raises ValueError at startup otherwise).
VAULT_MONITOR_ROOTS=

# VAULT_DROP_DEFAULT_COLLECTION: if set, root-level files in VAULT_DROP_ROOT
# (no subdir) get routed to this collection instead of being skipped.
# Empty = skip (legacy). Example: "_inbox" to implement "drop in _inbox
# and classify later" UX.
VAULT_DROP_DEFAULT_COLLECTION=

# OROIMEN_DEFAULT_COLLECTIONS: JSON list of PARA default collections to
# seed on first startup. Empty = no PARA seed (true opt-in). The legacy
# hardcoded 4 PARA defaults are no longer auto-seeded; you must set
# this env var explicitly if you want them (or pass PARA_DEFAULT_COLLECTIONS
# to seed_para_collections() programmatically).
# Format: '[{"name":"01_Proyectos","description":"...","sort_order":10}, ...]'
# Rename from HERMES_DEFAULT_COLLECTIONS per the project rename to
# Oroimen (Sprint 19 followup, 2026-07-12). Breaking change for
# existing installs: rename HERMES_DEFAULT_COLLECTIONS to
# OROIMEN_DEFAULT_COLLECTIONS in your .env.
OROIMEN_DEFAULT_COLLECTIONS=
# How often to poll PC availability. Default 30s. Cheap single HTTP probe.
EDGE_PROBE_INTERVAL_S=30.0


# ============================================================================
# Sprint 19.5 Slice 6 — Multi-Tier Embeddings Backend
# ============================================================================
# Optional multi-tier embedding configuration. The public Compose file
# supplies a local Ollama tier, so these values are only needed for a
# custom direct deployment. Every tier within one policy must use the
# same vector dimension.
#
# Per-tier config:
# - __ENABLED: true|1|yes|on (set to enable the tier; otherwise disabled)
# - __BASE_URL: HTTP(S) endpoint of the embedding service
# - __MODEL: model name (must be in the EmbeddingRouter.KNOWN_MODEL_DIMS registry)
# - __API_KEY: API key (empty for LAN tiers like NAS/edge)
# - __TIMEOUT_S: per-request timeout in seconds (default 30)

# --- Optional local tier ---
EMBEDDING_TIER_NAS__ENABLED=false
EMBEDDING_TIER_NAS__BASE_URL=
EMBEDDING_TIER_NAS__MODEL=granite-311m
# granite-311m produces 768-dimensional vectors. If it is also used for
# VAULT_INGEST, set VAULT_EMBEDDING_MODEL=granite-311m and
# VAULT_EMBEDDING_DIM=768, then re-embed any existing incompatible index.
EMBEDDING_TIER_NAS__API_KEY=
EMBEDDING_TIER_NAS__TIMEOUT_S=30.0

# --- Optional higher-capacity local tier ---
EMBEDDING_TIER_EDGE__ENABLED=false
EMBEDDING_TIER_EDGE__BASE_URL=
EMBEDDING_TIER_EDGE__MODEL=qwen3-embedding:8b
EMBEDDING_TIER_EDGE__API_KEY=
EMBEDDING_TIER_EDGE__TIMEOUT_S=30.0

# --- Optional cloud tier; enabling it sends embedding input off-host ---
EMBEDDING_TIER_CLOUD__ENABLED=false
EMBEDDING_TIER_CLOUD__BASE_URL=
EMBEDDING_TIER_CLOUD__MODEL=qwen/qwen3-embedding-8b
EMBEDDING_TIER_CLOUD__API_KEY=
EMBEDDING_TIER_CLOUD__TIMEOUT_S=30.0

# --- Policies (which tiers for which use case) ---
# Comma-separated list of tier names in priority order. The first
# enabled tier is the canonical (storage tier for embed_and_store,
# query tier for cosine_search). Subsequent tiers are fallbacks.
#
# chat_rag: per-message embedding for live chat RAG.
#   Default: "nas" (single tier, Option A per TDD v0.16 B-1 fix).
#   Other valid: "cloud" (cloud-only, no NAS dep), "edge" (edge-only,
#   privacy), "nas,edge" (mixed-dim — INVALID per Rule 3).
#
# vault_ingest: batch re-embed for the vault.
#   Default: "cloud,edge" (cloud 24/7 primary, edge fallback privacy).
#   Other valid: "edge,cloud" (edge primary when on), "edge" (edge only).
EMBEDDING_POLICY_CHAT_RAG=nas
EMBEDDING_POLICY_VAULT_INGEST=cloud,edge
